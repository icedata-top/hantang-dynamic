{
  "name": "bilibili-dynamic-subscribe",
  "version": "2.12.2",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist",
    "start": "tsx dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "biome lint",
    "format": "biome format",
    "check": "biome check",
    "lint:fix": "biome lint --fix",
    "format:fix": "biome format --fix",
    "check:fix": "biome check --fix",
    "package": "pkg dist/index.js --out-path dist/executables/ --compress Gzip --targets node20-win-x64,node20-macos-x64,node20-macos-arm64,node20-linux-x64,node20-linux-arm64 --no-bytecode --public",
    "relation": "tsx src/index.ts --relation",
    "repair": "tsx src/index.ts --repair"
  },
  "dependencies": {
    "@ahmedrangel/rand-user-agent": "^2.0.23",
    "axios": "^1.16.1",
    "axios-cookiejar-support": "^7.0.0",
    "cli-progress": "^3.12.0",
    "csv-parse": "^6.2.1",
    "mysql2": "^3.22.3",
    "nodemailer": "^8.0.8",
    "pg": "^8.21.0",
    "smol-toml": "^1.6.1",
    "tough-cookie": "^6.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@duckdb/node-api": "1.5.3-r.1",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/tough-cookie": "^4.0.5",
    "@vercel/ncc": "^0.38.4",
    "@yao-pkg/pkg": "^6.19.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
