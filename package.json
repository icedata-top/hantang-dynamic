{
  "name": "bilibili-dynamic-subscribe",
  "version": "2.12.2",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist",
    "start": "tsx dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "biome lint",
    "format": "biome format",
    "check": "biome check",
    "lint:fix": "biome lint --fix",
    "format:fix": "biome format --fix",
    "check:fix": "biome check --fix",
    "package": "pkg dist/index.js --out-path dist/executables/ --compress Gzip --targets node20-win-x64,node20-macos-x64,node20-macos-arm64,node20-linux-x64,node20-linux-arm64 --no-bytecode --public",
    "relation": "tsx src/index.ts --relation",
    "repair": "tsx src/index.ts --repair"
  },
  "dependencies": {
    "@ahmedrangel/rand-user-agent": "^2.0.23",
    "axios": "^1.14.0",
    "axios-cookiejar-support": "^6.0.5",
    "cli-progress": "^3.12.0",
    "csv-parse": "^6.2.1",
    "mysql2": "^3.20.0",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "smol-toml": "^1.6.1",
    "tough-cookie": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@duckdb/node-api": "1.5.0-r.1",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/tough-cookie": "^4.0.5",
    "@vercel/ncc": "^0.38.4",
    "@yao-pkg/pkg": "^6.14.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
